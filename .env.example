# SLG 极客号 AI 视频流水线 — 环境变量模板
# 复制本文件为 .env，填入你的 key（.env 已在 .gitignore，不会上传）

# === LLM Proxy (OpenAI-compatible，用于 step2 分镜生成 + step4 字幕 codex 抽取) ===
# 推荐：自建 LiteLLM Proxy / 直接用 OpenAI 兼容 API / Anthropic SDK
# 默认指向 OpenAI 官方，可替换为你的代理
LLM_PROXY_BASE_URL=https://api.openai.com/v1
LLM_PROXY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxx

# === 字节 火山 ICL TTS (用于 step1 配音克隆) ===
# 申请：https://console.volcengine.com/speech
VOLC_ICL_API_KEY=your_volcano_icl_api_key
VOLC_SPEAKER_ID=S_xxxxx  # 克隆训练后拿到的 voice_id

# === 字节 火山 Ark (用于 step3 视频生成 doubao-seedance) ===
# 申请：https://console.volcengine.com/ark
VOLC_ARK_API_KEY=your_volcano_ark_api_key

# === Atlas Skillhub 视频生成 Gateway (Lilith 内部) ===
# 外部用户可替换为快手 kling 直连 API + 字节 doubao-seedance 直连 API
ATLAS_SKILLHUB_TOKEN=your_atlas_skillhub_token
